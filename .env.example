# =============================================================================
# Configuración del sitio — copia este archivo a .env.local y llena las claves.
# La idea: clonar, poner estas claves en una llamada con el cliente, conectar el
# dominio, y listo. Todo lo configurable vive aquí.
# =============================================================================

# URL pública del sitio (con https, sin slash final). Se usa para el logo
# absoluto de los correos y los enlaces. Ej: https://midominio.com
NEXT_PUBLIC_SITE_URL=

# --- Correos (Resend) --------------------------------------------------------
# El formulario de contacto manda 2 correos brandeados con el sitio:
#   1. Notificación al dueño con el lead.  2. Agradecimiento al visitante.
# Sin RESEND_API_KEY el formulario responde "no configurado" (503).

# API key de Resend (https://resend.com/api-keys).
RESEND_API_KEY=

# Remitente. Debe ser un dominio/correo VERIFICADO en Resend para producción.
# Ej: "Mi Negocio <contacto@midominio.com>". Sin verificar, usa el default de
# Resend (onboarding@resend.dev) — sirve para pruebas, no para prod.
CONTACT_FROM=

# A quién le llegan los leads del formulario. Uno o VARIOS correos separados por
# coma. Ej: ventas@midominio.com,dueno@midominio.com
LEAD_NOTIFY_TO=
